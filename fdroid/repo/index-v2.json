{"repo": {"name": {"en-US": "restoid"}, "description": {"en-US": "Releases published from GitHub tags for restoid."}, "icon": {"en-US": {"name": "/icons/icon.png", "sha256": "8f30be3cd0423a3518b34a560dd19ec52bdac487b83ce073cee0591e096684a9", "size": 680}}, "address": "https://hddq.github.io/restoid/fdroid/repo", "timestamp": 1777730705000, "categories": {"System": {"name": {"en-US": "System"}}}}, "packages": {"io.github.hddq.restoid": {"metadata": {"added": 1777730697000, "categories": ["System"], "issueTracker": "https://github.com/hddq/restoid/issues", "lastUpdated": 1777730703000, "license": "GPL-3.0-only", "sourceCode": "https://github.com/hddq/restoid", "translation": "https://hosted.weblate.org/projects/restoid", "screenshots": {"phone": {"en-US": [{"name": "/io.github.hddq.restoid/en-US/phoneScreenshots/1.png", "sha256": "2626fbd2049d836c12d74a8243b0d1d98d16d4d9713ad95823212fcf7ceabc0a", "size": 106823}, {"name": "/io.github.hddq.restoid/en-US/phoneScreenshots/2.png", "sha256": "7f209b37c94027bf880ba5fd4b023a010b871442876737b6cc694562b0d4a66b", "size": 165573}, {"name": "/io.github.hddq.restoid/en-US/phoneScreenshots/3.png", "sha256": "a6121a3dedb2e48dabb1ca91b26e637dc0af30d74193aedb92f5d160b3957a04", "size": 164113}, {"name": "/io.github.hddq.restoid/en-US/phoneScreenshots/4.png", "sha256": "96c38af635ad6e34554088833e9b2c77c199bd1411e6c6e5a0f2d7e1dd361809", "size": 134860}, {"name": "/io.github.hddq.restoid/en-US/phoneScreenshots/5.png", "sha256": "1be75bdee091b5283e93c7b13460832280bc29a583c09b00467c8b3824b1ac03", "size": 124177}, {"name": "/io.github.hddq.restoid/en-US/phoneScreenshots/6.png", "sha256": "7af6d3a361d359703eb4a8f2b9f9012f6c73807dcc74e75d1fba0ac77850d672", "size": 191478}, {"name": "/io.github.hddq.restoid/en-US/phoneScreenshots/7.png", "sha256": "fcb9382c202002e88b92e445ccc5e524c472e04bc658d8d10a8c3cbfa8c3777b", "size": 177197}]}}, "authorName": "hddq", "name": {"en-US": "Restoid"}, "summary": {"en-US": "A modern, root-based Android app backup tool powered by restic"}, "description": {"en-US": "Restoid gives you complete control over your app backups through a clean, modern, and simple user interface. Powered by the open-source \"restic\" engine, it's built for users who demand robust, encrypted, and deduplicated backups.\n\nRoot access is strictly required to read and write private application data directories.\n\nFeatures:\n* Restic-Powered: Leverages the speed, security, and efficiency of restic for local, deduplicated, and encrypted backups.\n* Selective Backup: Choose exactly which user-installed applications you want to save.\n* Granular Control: Granularly select what to include for each app: APK files, user data, device-protected data, external/OBB, or media files.\n* Flexible Storage: Create and manage backup repositories on your device's internal storage, SD card, or mounted external drives.\n* Snapshot Management: Easily browse historical backup snapshots, view details of what was backed up, and forget old data to save space.\n* Surgical Restore: Restore entire apps completely, or just specific parts (like restoring only app data without overwriting the APK).\n* Downgrade Protection: Prevents you from accidentally restoring an older app version over a newer one."}, "icon": {"en-US": {"name": "/io.github.hddq.restoid/en-US/icon_yVJRms5RED-ZaFglb4VbCjpMhkeZPz8Ynug3RPzFb9E=.png", "sha256": "c952519ace51103f996858256f855b0a3a4c8647993f3f189ee83744fcc56fd1", "size": 19671}}, "preferredSigner": "f15f66103ee8daaf23c3913025500f08ef360849a69c427bed7db7016c3b14d3"}, "versions": {"d6511cb22e76cee880a95bede05d96a6f69dbb4eaff2a24148c6fb3be787713e": {"added": 1777730703000, "file": {"name": "/app-x86_64-release-v0.4.3.apk", "sha256": "d6511cb22e76cee880a95bede05d96a6f69dbb4eaff2a24148c6fb3be787713e", "size": 73151662}, "manifest": {"nativecode": ["x86_64"], "versionName": "0.4.3", "versionCode": 132, "usesSdk": {"minSdkVersion": 33, "targetSdkVersion": 36}, "signer": {"sha256": ["f15f66103ee8daaf23c3913025